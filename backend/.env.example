# FinSight Environment Variables

# LLM Provider: "local" (Llama 3.2 3B) or "groq" (Groq API)
LLM_PROVIDER=local

# Groq API Key (only needed if LLM_PROVIDER=groq)
GROQ_API_KEY=

# Tavily API Key (free tier, for news search)
TAVILY_API_KEY=

# NewsAPI.org Key (free tier: 100 req/day, supplements Tavily news)
NEWSAPI_KEY=

# Finnhub API Key (free tier: 60 req/min — news, earnings surprises, insider sentiment)
FINNHUB_API_KEY=

# SEC EDGAR User-Agent (required by SEC policy)
SEC_USER_AGENT=FinSight anmol@example.com
