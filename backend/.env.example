# FinSight backend environment variables.
# Copy to `.env` and fill in. All values below mirror backend/config.py.
# Nothing here is required for the app to boot — every field has a default —
# but LLM calls and most data tools need their respective keys to return live data.

# ---------- LLM provider ----------
# One of: "gemini" (default), "groq", "fallback", or "local".
# "local" requires HF_TOKEN + a GPU and is opt-in — do not set it without that hardware.
LLM_PROVIDER=gemini

# Gemini API key (used when LLM_PROVIDER=gemini, the default)
GEMINI_API_KEY=

# Groq API key (only needed when LLM_PROVIDER=groq)
GROQ_API_KEY=

# HuggingFace token — required for gated models / local LLM inference (LLM_PROVIDER=local)
# AND for the sentiment API backend (SENTIMENT_BACKEND=api). For the API backend the
# token needs the "Inference Providers" permission.
HF_TOKEN=

# HuggingFace model ID for local inference (only used when LLM_PROVIDER=local)
LOCAL_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# ---------- Data-tool API keys ----------
# Tavily API key (free tier, for news search)
TAVILY_API_KEY=

# NewsAPI.org key (free tier: 100 req/day, supplements Tavily news)
NEWSAPI_KEY=

# Finnhub API key (free tier: 60 req/min — news, earnings surprises, insider sentiment)
FINNHUB_API_KEY=

# SEC EDGAR User-Agent (required by SEC policy — use a real contact email)
SEC_USER_AGENT=FinSight anmol@example.com

# ---------- Sentiment backend ----------
# FinBERT sentiment backend: "local" (default, in-process, ~2GB RAM, no network)
# or "api" (HuggingFace serverless Inference API — keeps the process small for
# low-RAM hosts like Render/Fly free tiers; requires HF_TOKEN above).
SENTIMENT_BACKEND=local

# Model ID + per-request timeout (seconds) for the API backend. Defaults shown.
HF_INFERENCE_MODEL=ProsusAI/finbert
HF_INFERENCE_TIMEOUT=30

# ---------- Database ----------
# SQLite DB path. Defaults to backend/data/finsight.db if unset.
DB_PATH=

# ---------- CORS ----------
# Comma-separated allowed origins (e.g. "https://app.example.com,https://x.vercel.app").
# Defaults to "*". Set explicitly in production to your frontend origin(s).
ALLOWED_ORIGINS=*

# ---------- Auth (Supabase JWT) ----------
# Supabase JWT secret (Project Settings → API → JWT Secret).
# When set, all data endpoints require a valid Supabase bearer token.
# When empty (local dev), auth is DISABLED only if AUTH_DISABLED=true below;
# otherwise protected routes fail closed (503).
SUPABASE_JWT_SECRET=

# Local-dev escape hatch: bypass JWT auth entirely. Leave false in production.
AUTH_DISABLED=false

# ---------- Rate limiting ----------
# slowapi limit for /analyze and /stream, per client IP. Guards free-tier API quotas.
ANALYZE_RATE_LIMIT=10/minute
